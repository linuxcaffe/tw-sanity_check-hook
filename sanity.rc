# sanity.rc — Configuration for sanity-check
# Copy to ~/.task/config/sanity.rc and edit to taste.
#
# Include in .taskrc with:
#   include ~/.task/config/sanity.rc
#
# Global settings:
#   sanity.clear-term = task | condition | type | no
#
# Each condition has:
#   description   short label shown in status/menu
#   filter        Taskwarrior filter expression
#   msg           heading shown during interactive review
#   sort          field± to sort by (e.g. due+, urgency-)
#   action        comma-separated fix options: "label|template, label|template"
#                 tokens: <field>  <field±Nd/w/m/y>  e.g. <due+1w>
#   helpers       optional: calendar  (adds c=calendar hotkey)
#   type          special handler: orphans | diag  (omit for normal filter)

sanity.clear-term = task

condition.late-due.description = Tasks with past due dates
condition.late-due.filter      = +PENDING due.before:today-2d
condition.late-due.msg         = This task is overdue! - reschedule or clear
condition.late-due.sort        = due+
condition.late-due.action      = edit|mod due:, due tomorrow|mod due:<today+1d>, due next week|mod due:<today+7d>, clear due date|mod due:
condition.late-due.helpers     = calendar

condition.late-sched.description = Tasks with past scheduled dates
condition.late-sched.filter      = +PENDING scheduled.before:today-1d
condition.late-sched.msg         = This task is past it's sched:date — reschedule or clear
condition.late-sched.sort        = scheduled+
condition.late-sched.action      = edit|mod scheduled:, do it tomorrow|mod scheduled:<today+1d>, do it next week|mod scheduled:<today+7d>, clear scheduled:date|mod scheduled:
condition.late-sched.helpers     = calendar

condition.scheduled-after-due.description = Scheduled date is after due:date
condition.scheduled-after-due.filter      = +PENDING scheduled.after:due
condition.scheduled-after-due.msg         = Tasks should be scheduled before they are due
condition.scheduled-after-due.sort        = due+,scheduled+
condition.scheduled-after-due.action      = edit|mod scheduled:, sched:due-1d|mod scheduled:<due-1d>, sched:due-1w|mod scheduled:due-1w, clear scheduled:date|mod scheduled:
condition.scheduled-after-due.helpers     = calendar

condition.until-before-due-sched.description = Task expires before its due or scheduled date
condition.until-before-due-sched.filter      = +PENDING ( until.before:due or until.before:scheduled )
condition.until-before-due-sched.msg         = This task will be deleted before it is due!
condition.until-before-due-sched.sort        = due+
condition.until-before-due-sched.action      = edit|mod until:, expire 1 day after due|mod until:<due+1w>, clear until:date|mod until:
condition.until-before-due-sched.helpers     = calendar

condition.wait-after-due-sched.description = Wait date is after due or sched date (hidden until it's late)
condition.wait-after-due-sched.filter      = +PENDING wait.after:due or wait.after:scheduled
condition.wait-after-due-sched.msg         = Task will appear in the list after it's already due
condition.wait-after-due-sched.sort        = due+,scheduled+
condition.wait-after-due-sched.action      = edit|mod wait:, wait:due-1d|mod wait:<due-1d>, wait:due-1w|mod wait:due-1w, clear wait:date|mod wait:
condition.wait-after-due-sched.helpers     = calendar

#condition.wait-after-scheduled.description = Wait date is after scheduled date
#condition.wait-after-scheduled.filter      = +PENDING wait.after:scheduled
#condition.wait-after-scheduled.msg         = Task will appear after its scheduled time
#condition.wait-after-scheduled.sort        = scheduled+
#condition.wait-after-scheduled.action      = wait day before scheduled|mod wait:<scheduled-1d>, remove wait|mod wait:
#condition.wait-after-scheduled.helpers     = calendar

condition.orphans.description = Blocked tasks with completed/deleted parent
condition.orphans.filter      = +PENDING +BLOCKED
condition.orphans.msg         = Stale dependencies — parent task is no longer active
condition.orphans.sort        = urgency-
condition.orphans.action      = remove dep|mod dep:
condition.orphans.type        = orphans

condition.diag-hooks.description = Hooks that are inactive or not executable
condition.diag-hooks.msg         = Hook problems found — library files excluded
condition.diag-hooks.type        = diag-hooks

condition.diag-broken.description = Tasks with broken dependency references
condition.diag-broken.msg         = Dependency UUID no longer exists in task database
condition.diag-broken.type        = diag-broken

condition.diag-dups.description = Tasks with duplicate UUIDs
condition.diag-dups.msg         = Duplicate UUIDs — manual investigation needed
condition.diag-dups.type        = diag-dups

# ─────────────────────────────────────────────────────────────────────────────
# type=args conditions — invoked by CLI arg pattern: sanity-check project:X
#
# attrib= names the argument prefix to match:
#   project:work   → attrib=project, <arg>=work
#   priority:H     → attrib=priority, <arg>=H
#   +urgent        → attrib=+, <arg>=urgent
#
# <arg> is substituted in filter, msg, and action at runtime.
# First-in-wins when multiple attrib-matching args are given.
# ─────────────────────────────────────────────────────────────────────────────

condition.args-project.attrib      = project
condition.args-project.description = Pending tasks in project:<arg>
condition.args-project.filter      = +PENDING project:<arg>
condition.args-project.msg         = project:<arg> — review and triage
condition.args-project.sort        = urgency-
condition.args-project.action      = list <args> project tasks|!task list project:<args>, edit|mod project:, edit due|mod due:, done|, del|rc.confirmation=off del
condition.args-project.type        = args

condition.args-priority.attrib     = priority
condition.args-priority.description = Pending tasks with priority:<arg>
condition.args-priority.filter     = +PENDING priority:<arg>
condition.args-priority.msg        = priority:<arg> tasks — review and triage
condition.args-priority.sort       = urgency-
condition.args-priority.action     = edit|mod priority:, edit due|mod due:, done|, lower priority|mod priority:M
condition.args-priority.type       = args

condition.args-tag.attrib          = +
condition.args-tag.description     = Pending tasks tagged +<arg>
condition.args-tag.filter          = +PENDING +<arg>
condition.args-tag.msg             = +<arg> tasks — review and triage
condition.args-tag.sort            = urgency-
condition.args-tag.action          = edit|mod , edit due|mod due:, done|, remove tag|mod -<arg>
condition.args-tag.type            = args
