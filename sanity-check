def _run_edit(prefill: str, tid, skip_uuids: set, uuid: str,
              remaining: list, session_action: Optional[list] = None) -> Optional[bool]:
    """Open readline edit prompt. Returns True=advanced, False=quit, None=loop."""
    response = prompt_prefill('  > ', prefill)
    if response is None:
        return None  # Ctrl-C → loop
    response = response.strip()
    if not response or response.lower() == 's':
        skip_uuids.add(uuid)
        remaining.pop(0)
        return True
    elif response.lower() == 'q':
        return False
    elif response.lower() == 'd' and tid:
        subprocess.run(['task', 'rc.confirmation=off', str(tid), 'done'])
        remaining.pop(0)
        return True
    else:
        parts = response.split()
        if parts and parts[0] == 'task':
            parts = ['task', 'rc.confirmation=off', 'rc.verbose=nothing'] + parts[1:]
        result = subprocess.run(parts)
        if result.returncode == 0:
            if session_action is not None:
                session_action[0] = True
            remaining.pop(0)
            if remaining:
                _getch()
            return True
        else:
            print('  [command failed — edit and retry, or Enter to skip]')
            return None


def review_condition(cond: dict, tasks: list, clear_term: str = 'no',
                     session_action: Optional[list] = None,
                     timeout_msg: float = 0) -> bool:
    """Interactive review of one condition. Returns False to quit session.

    session_action is a [bool] mutable flag shared across conditions — set True
    on any successful action to enable u=undo for the rest of the session.
    """
    if session_action is None:
        session_action = [False]
    name    = cond['name']
    msg     = cond.get('msg', name)
    total   = len(tasks)
    has_cal = 'calendar' in cond.get('helpers', '')
    actions = parse_actions(cond.get('action', ''))

    if clear_term == 'condition':
        clear_screen()

    print(f'\n{"═" * 62}')
    msg_display = msg.replace('\\n', '\n    ')
    print(f'  {name} — {msg_display}')
    print(f'  {total} task{"s" if total != 1 else ""}')
    print(f'{"═" * 62}')

    if not tasks:
        print('  Nothing to fix.')
        return True

    # Informational-only conditions
    if cond.get('type') in ('diag', 'diag-dups'):
        for t in tasks:
            print(f'  ▶ {t["description"]}')
        input('\n  Press Enter to continue...')
        return True

    skip_uuids = set()
    remaining  = list(tasks)
    show_cal   = False

    _CAL_CMD = ['task',
                'rc.verbose=nothing',
                'rc.calendar.details=none',
                'rc.calendar.legend=0',
                'rc.calendar.monthsperline=4',
                'rc.displayweeknumber=0',
                'calendar']

    while remaining:
        task = remaining[0]
        uuid = task.get('uuid', '')

        if uuid in skip_uuids:
            remaining.pop(0)
            continue

        task_msg = compute_action(msg, task, colorize=True).replace('\\n', '\n    ')

        if clear_term == 'task':
            clear_screen()
            # Re-show condition context after clear
            print(f'  {CYAN}{name}{RESET} — {task_msg}')
            print(DIVIDER)
            if show_cal:
                subprocess.run(_CAL_CMD)

        done_count = total - len(remaining)
        show_task(task)

        tid       = task.get('id') or 0
        is_pseudo = not bool(tid)
        task_ref  = tid if tid else uuid  # waiting tasks have id=0; fall back to UUID

        # Actions: per-task prebuilt (_actions) or computed from condition template
        if '_actions' in task:
            computed = [(lbl, cmd, False) for lbl, cmd in task['_actions']]
        else:
            computed = []
            for label, template, open_edit in actions:
                cmd = compute_action(template, task)
                is_shell = cmd.startswith('!')
                if not is_shell and re.search(r'<\w', cmd):
                    continue  # unresolved token — field absent on this task
                lbl = compute_action(label, task, colorize=True)
                if is_shell:
                    final_cmd = cmd         # shell cmd — no task ref, run as-is
                elif cmd:
                    final_cmd = f'task {task_ref} {cmd}'
                else:
                    final_cmd = ''
                computed.append((lbl, final_cmd, open_edit))

        # Numbered fixes
        print()
        if computed:
            lw = max((len(lbl) for lbl, _, _ in computed if lbl), default=0)
            for i, (label, cmd, open_edit) in enumerate(computed, 1):
                lbl_str = f'{label:<{lw}}  ' if label else ''
                print(f'  {YELLOW}{i}{RESET}  {lbl_str}{cmd}')
        elif actions:
            print(f'  {DIM}[no applicable fixes for this task]{RESET}')

        # Letter hotkeys — suppress task-specific ones for pseudo-tasks
        hotkeys = []
        if has_cal and not is_pseudo:
            cal_label = 'c=hide-cal' if show_cal else 'c=calendar'
            hotkeys.append(cal_label)
        if not is_pseudo:
            hotkeys += ['i=info', 'd=done']
        if session_action[0]:
            hotkeys.append('u=undo')
        hotkeys.append('q=quit')
        print(f'\n  ({done_count + 1}/{total})  {CYAN}{"  ".join(hotkeys)}{RESET}  Enter=skip')
        print('  > ', end='', flush=True)
        key = _getch()

        if key in ('\x03', '\x1b', 'q', 'Q'):
            return False

        elif key in ('\r', '\n'):
            skip_uuids.add(uuid)
            remaining.pop(0)

        elif key in ('d', 'D') and not is_pseudo:
            subprocess.run(['task', 'rc.hooks=off', 'rc.confirmation=off',
                            'rc.verbose=label,affected', str(task_ref), 'done'])
            session_action[0] = True
            remaining.pop(0)
            if remaining:
                if timeout_msg > 0:
                    print(f'  [next in {timeout_msg:.0f}s, or any key]', end='', flush=True)
                    _timed_getch(timeout_msg)
                else:
                    _getch()

        elif key in ('u', 'U') and session_action[0]:
            subprocess.run(['task', 'rc.hooks=off', 'undo'])
            _getch()

        elif key in ('c', 'C') and has_cal and not is_pseudo:
            show_cal = not show_cal
            # loop — re-renders with/without calendar

        elif key in ('i', 'I') and not is_pseudo:
            subprocess.run(['task', 'rc.verbose=nothing', 'rc.journal.info=0',
                            'rc.hooks=off', str(task_ref), 'info'])
            _getch()  # any key to dismiss, then re-render

        elif key.isdigit() and 1 <= int(key) <= len(computed):
            label, cmd, open_edit = computed[int(key) - 1]
            if open_edit:
                r = _run_edit(cmd or f'task {task_ref} ', tid, skip_uuids, uuid, remaining, session_action)
                if r is False:
                    return False
            elif cmd:
                if re.search(r'<\w', cmd):
                    unresolved = re.findall(r'<[^>]+>', cmd)
                    fields = ', '.join(u.strip('<>').split('-')[0].split('+')[0] for u in unresolved)
                    print(f'  [skipped — task has no {fields} date]  (any key to continue)')
                    _getch()
                elif cmd.startswith('!'):
                    subprocess.run(cmd[1:], shell=True)
                    print('  [press any key to continue]', end='', flush=True)
                    _getch()
                else:
                    parts = cmd.split()
                    if parts and parts[0] == 'task':
                        parts = ['task', 'rc.hooks=off', 'rc.confirmation=off',
                                 'rc.verbose=label,affected'] + parts[1:]
                    result = subprocess.run(parts)
                    if result.returncode == 0:
                        session_action[0] = True
                        remaining.pop(0)
                        if remaining:
                            if timeout_msg > 0:
                                print(f'  [next in {timeout_msg:.0f}s, or any key]', end='', flush=True)
                                _timed_getch(timeout_msg)
                            else:
                                _getch()
                    else:
                        print('  [command failed — press any key to skip]')
                        _getch()
            else:
                print('  [no command for this task]')

        # unrecognised key: loop, show task again

    print(f'\n  ✓ {name} complete')
    return True


