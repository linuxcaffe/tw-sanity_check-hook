def _getch() -> str:
    """Read one keypress in raw mode; falls back to line input if not a TTY."""
    if not sys.stdin.isatty():
        line = sys.stdin.readline()
        return (line.strip()[:1] if line.strip() else '\r')
    try:
        import tty, termios
    except ImportError:
        ch = input().strip()
        return ch[:1] if ch else '\r'
    fd  = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        ch = sys.stdin.read(1)
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
    sys.stdout.write('\n')
    sys.stdout.flush()
    return ch


def _timed_getch(seconds: float) -> str:
    """Like _getch() but auto-returns '' after `seconds` if no key pressed."""
    if not sys.stdin.isatty() or seconds <= 0:
        return _getch()
    try:
        import tty, termios, select as _sel
        fd  = sys.stdin.fileno()
        old = termios.tcgetattr(fd)
        try:
            tty.setraw(fd)
            ready, _, _ = _sel.select([sys.stdin], [], [], seconds)
            ch = sys.stdin.read(1) if ready else ''
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)
        sys.stdout.write('\n')
        sys.stdout.flush()
        return ch
    except Exception:
        return _getch()


def _restore_terminal():
    """Restore terminal to the clean state saved at startup."""
    if _SAVED_TC is not None:
        try:
            import termios
            termios.tcsetattr(sys.stdin.fileno(), termios.TCSAFLUSH, _SAVED_TC)
        except Exception:
            pass

_atexit.register(_restore_terminal)


def prompt_prefill(prompt_text: str, prefill: str) -> Optional[str]:
    """Returns the edited string, or None if the user pressed Ctrl-C."""
    result = None
    try:
        import readline
        readline.set_startup_hook(lambda: readline.insert_text(prefill))
        try:
            result = input(prompt_text)
        except KeyboardInterrupt:
            # Restore terminal BEFORE writing anything — readline's raw-ish
            # mode disables NL→CRNL translation, causing a staircase if we
            # print before restoring.
            _restore_terminal()
            sys.stdout.write('\r\n')
            sys.stdout.flush()
        finally:
            readline.set_startup_hook(None)
    except ImportError:
        try:
            result = input(f'{prompt_text}[{prefill}] ')
        except KeyboardInterrupt:
            print()
    finally:
        _restore_terminal()  # idempotent; covers all paths

    return result


