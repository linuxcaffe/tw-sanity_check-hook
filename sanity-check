def _rjust_line(left: str, right: str) -> str:
    """Left content + right-justified label within DIVIDER width."""
    pad = len(DIVIDER) - len(left) - len(right)
    return left + ' ' * max(pad, 2) + right


def _type_group(cond: dict) -> str:
    """Normalize condition type to its top-level display group."""
    t = cond.get('type', '') or 'filter'
    if t.startswith('diag'):
        return 'diag'
    return t


def _bind_arg(cond: dict, arg: str) -> dict:
    """Return a copy of cond with <arg> substituted in all string fields."""
    result = dict(cond)
    for key in ('filter', 'msg', 'action', 'description'):
        if key in result:
            result[key] = result[key].replace('<arg>', arg)
    return result


def _conditions_menu(conditions: list, clear_term: str, timeout_msg: float,
                     session_action: list) -> bool:
    """Flat numbered conditions menu. Returns False to quit session, True to go back."""
    while True:
        agenda = [(cond, collect_tasks(cond)) for cond in conditions]
        total  = sum(len(tasks) for _, tasks in agenda)
        width  = max(len(c['name']) for c in conditions) if conditions else 10

        print(DIVIDER)
        for i, (cond, tasks) in enumerate(agenda, 1):
            n    = len(tasks)
            flag = '▶ ' if n else '  '
            desc = cond.get('description', '')
            row  = f'  {flag}{i:>2}. {cond["name"]:<{width}}  {n:>3}   {desc}'
            print(f'{DIM}{row}{RESET}' if n == 0 else row)
        print(DIVIDER)

        if total == 0:
            print('  All clear.')
            print('  (any key to continue)', end='', flush=True)
            _getch()
            return True

        use_getch = len(agenda) < 10
        print(f'\n  Select [1-{len(agenda)}]  a=all  q=quit  Enter=back')
        if use_getch:
            key = _getch()
        else:
            try:
                key = input('  > ').strip() or '\r'
            except (KeyboardInterrupt, EOFError):
                print()
                return True

        if not key or key in ('\x03', '\x1b', 'q', 'Q'):
            return False
        elif key in ('\r', '\n'):
            return True
        elif key.lower() == 'a':
            selected = agenda
        else:
            try:
                n = int(key)
                if 1 <= n <= len(agenda):
                    selected = [agenda[n - 1]]
                else:
                    print(f'  Out of range: {n}')
                    continue
            except ValueError:
                print(f'  Unknown: {key!r}')
                continue

        print()
        for cond, tasks in selected:
            if not tasks:
                print(f'  No matches found: {cond.get("description", cond["name"])}')
                continue
            if not review_condition(cond, tasks, clear_term, session_action, timeout_msg):
                print('\n[sanity-check] Session ended.')
                return False
        print()


def cmd_menu(conditions: list, clear_term: str = 'no', timeout_msg: float = 0):
    session_action = [False]  # shared across all conditions this session
    menu_conds = [c for c in conditions if _type_group(c) != 'args']

    while True:
        if clear_term == 'type':
            clear_screen()
        today = date.today().strftime('%Y-%m-%d')
        diag  = _parse_diag_header()
        stats = _run_stats()
        agenda = [(cond, collect_tasks(cond)) for cond in menu_conds]
        total  = sum(len(tasks) for _, tasks in agenda)

        n_str = f'{total} issue{"s" if total != 1 else ""}' if total else 'all clear'
        print('\n' + _rjust_line(f'Taskwarrior Sanity check — {n_str}', today))
        print(DIVIDER)

        ver_plat = diag['version']
        if diag['platform']:
            ver_plat += f' - Platform: {diag["platform"]}'
        if ver_plat:
            print(ver_plat)

        m = re.match(r'task (\d+)\.(\d+)', diag.get('version', ''))
        if m:
            major, minor = int(m.group(1)), int(m.group(2))
            if major >= 3:
                print(f'{BOLD}WARNING: Taskwarrior {major}.x is untested — '
                      f'expect significant breakage{RESET}')
            elif major < 2 or (major == 2 and minor < 6):
                print(f'{BOLD}WARNING: Taskwarrior {major}.{minor} is too old — '
                      f'some features may be missing{RESET}')

        if diag['file']:
            print(f'File:{diag["file"]}')
        if diag['data']:
            print(f'Data:{diag["data"]}')

        print(DIVIDER)

        stat_keys = ['Pending', 'Waiting', 'Recurring', 'Completed', 'Deleted', 'Total']
        W = 20
        for key in stat_keys:
            val = stats.get(key, '')
            if not val:
                continue
            left = f'{key:<{W}}{val:>6}'
            if key == 'Total':
                print(_rjust_line(left, 'see: task stats'))
            else:
                print(left)

        print(DIVIDER)

        # Group conditions by type for the top-level menu
        groups = {}
        for cond, tasks in agenda:
            g = _type_group(cond)
            if g not in groups:
                groups[g] = []
            groups[g].append((cond, tasks))

        type_names = list(groups.keys())
        for i, tname in enumerate(type_names, 1):
            g_tasks = sum(len(t) for _, t in groups[tname])
            n_conds = len(groups[tname])
            flag = '▶ ' if g_tasks else '  '
            cond_label = f'{n_conds} condition{"s" if n_conds != 1 else ""}'
            issue_label = f'{g_tasks} issue{"s" if g_tasks != 1 else ""}'
            row = f'  {flag}{i:>2}. {tname:<10}  {cond_label:<16}  {issue_label}'
            print(f'{DIM}{row}{RESET}' if g_tasks == 0 else row)

        print(DIVIDER)
        if total == 0:
            print('  All clear.\n')
            return

        print(f'\n  Select [1-{len(type_names)}]  a=all  q=quit')
        key = _getch()

        if not key or key in ('\x03', '\x1b', 'q', 'Q', '\r', '\n'):
            return
        elif key.lower() == 'a':
            if not _conditions_menu(menu_conds, clear_term, timeout_msg, session_action):
                return
        elif key.isdigit() and 1 <= int(key) <= len(type_names):
            tname = type_names[int(key) - 1]
            group_conds = [cond for cond, _ in groups[tname]]
            if len(group_conds) == 1:
                cond, tasks = groups[tname][0]
                if tasks:
                    if not review_condition(cond, tasks, clear_term, session_action, timeout_msg):
                        print('\n[sanity-check] Session ended.')
                        return
                else:
                    print(f'\n  No matches: {cond.get("description", cond["name"])}')
                    print('  (any key to continue)', end='', flush=True)
                    _getch()
            else:
                if not _conditions_menu(group_conds, clear_term, timeout_msg, session_action):
                    return
        else:
            print(f'  Unknown: {key!r}')
        print()


# ============================================================================
# Main
# ============================================================================

def main() -> int:
    # Load sanity.rc first (its definitions take precedence)
    visited = set()
    global_cfg, conditions = load_rc(CONFIG_FILE, visited)
    # Plugin pattern: scan .taskrc include chain for additional condition blocks.
    # visited already contains sanity.rc so it won't be re-read.
    _, extra_conds = load_rc(TASKRC, visited)
    known_names = {c['name'] for c in conditions}
    for cond in extra_conds:
        if cond['name'] not in known_names:
            conditions.append(cond)

    if not conditions:
        print(f'[sanity-check] No conditions found in {CONFIG_FILE}', file=sys.stderr)
        return 1

    clear_term  = global_cfg.get('clear-term', 'no').lower()
    timeout_msg = float(global_cfg.get('timeout.affected-msg', 0) or 0)

    args = sys.argv[1:]

    if not args:
        cmd_menu(conditions, clear_term, timeout_msg)
        return 0

    # type=args dispatch: "attrib:value" or "+tag" patterns — first match wins
    # Any remaining args after the matched one are appended to the filter.
    args_conds = [c for c in conditions if c.get('type') == 'args']
    if args_conds:
        bound_conds = []
        for a in args:
            if a.startswith('+') and len(a) > 1:
                matched = [c for c in args_conds if c.get('attrib') == '+']
                if matched:
                    extra = ' '.join(x for x in args if x != a)
                    bound_conds = []
                    for c in matched:
                        b = _bind_arg(c, a[1:])
                        if extra:
                            b['filter'] = b['filter'] + ' ' + extra
                        bound_conds.append(b)
                    break
            elif ':' in a:
                attrib, _, value = a.partition(':')
                matched = [c for c in args_conds if c.get('attrib') == attrib]
                if matched:
                    extra = ' '.join(x for x in args if x != a)
                    bound_conds = []
                    for c in matched:
                        b = _bind_arg(c, value)
                        if extra:
                            b['filter'] = b['filter'] + ' ' + extra
                        bound_conds.append(b)
                    break
        if bound_conds:
            agenda = [(cond, collect_tasks(cond)) for cond in bound_conds]
            total  = sum(len(tasks) for _, tasks in agenda)
            if total == 0:
                print('\nAll clear — no issues found.')
                return 0
            print(f'\nSanity check — {date.today().strftime("%Y-%m-%d")}')
            for cond, tasks in agenda:
                if tasks:
                    print(f'  ▶ {cond["name"]:<24} {len(tasks):>3} task{"s" if len(tasks) != 1 else ""}')
            print()
            session_action = [False]
            for cond, tasks in agenda:
                if not tasks:
                    continue
                if not review_condition(cond, tasks, clear_term, session_action):
                    print('\n[sanity-check] Session ended.')
                    break
            print()
            return 0

    target = args[0].lower()

    if target == 'all':
        selected = conditions
    else:
        # Exact name match first, then type-prefix match for grouping
        selected = [c for c in conditions if c['name'] == target]
        if not selected:
            selected = [c for c in conditions
                        if c.get('type', '').startswith(target)]
        if not selected:
            print(f'[sanity-check] Unknown condition or type: {target}', file=sys.stderr)
            print(f'  Known conditions: {", ".join(c["name"] for c in conditions)}',
                  file=sys.stderr)
            known_types = sorted({c["type"] for c in conditions if c.get("type")})
            if known_types:
                print(f'  Known types: {", ".join(known_types)}', file=sys.stderr)
            return 1

    agenda = [(cond, collect_tasks(cond)) for cond in selected]
    total  = sum(len(tasks) for _, tasks in agenda)

    if total == 0:
        print('\nAll clear — no issues found.')
        return 0

    print(f'\nSanity check — {date.today().strftime("%Y-%m-%d")}')
    for cond, tasks in agenda:
        if tasks:
            print(f'  ▶ {cond["name"]:<24} {len(tasks):>3} task{"s" if len(tasks) != 1 else ""}')
    print()

    session_action = [False]
    for cond, tasks in agenda:
        if not tasks:
            continue
        if not review_condition(cond, tasks, clear_term, session_action):
            print('\n[sanity-check] Session ended.')
            break

    print()
    return 0


if __name__ == '__main__':
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        print()
        sys.exit(0)
