def load_rc(rc_file, _visited: Optional[set] = None) -> tuple:
    """Parse rc file, following include directives.

    Wraps tw_condition_lib.load_rc with app_prefix='sanity' so that
    'sanity.foo' keys arrive in global_cfg as 'foo'.
    """
    return __import__('tw_condition_lib').load_rc(
        rc_file, app_prefix='sanity', _visited=_visited
    )


def parse_actions(action_str: str) -> list:
    """Parse 'label|template, ...' → [(label, template, open_edit), ...].
    If label starts with 'edit' or 'mod' (e.g. 'edit due', 'mod priority'),
    selecting that numbered option opens readline pre-filled with the template
    instead of running the command directly."""
    result = []
    for item in action_str.split(','):
        item = item.strip()
        if not item:
            continue
        if '|' in item:
            label, _, template = item.partition('|')
            label = label.strip()
            words = label.lower().split()
            open_edit = bool(words and words[0] in ('edit', 'mod'))
            result.append((label, template.strip(), open_edit))
        else:
            result.append(('', item.strip(), False))
    return result


