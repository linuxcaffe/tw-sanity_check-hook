#!/usr/bin/env python3
"""
sanity-check — Review and fix common Taskwarrior inconsistencies

Usage:
    sanity-check              Numbered menu: pick a condition to review
    sanity-check all          Interactive review of all conditions
    sanity-check <condition>  Interactive review of one condition

Config:  ~/.task/config/sanity.rc
Install: ~/.task/scripts/sanity-check
Version: 0.5.0
"""

import json
import os
import re
import subprocess
import sys
from datetime import date, datetime, timedelta
from pathlib import Path
from typing import Optional

# Save clean terminal state at startup so we can always restore it
_SAVED_TC = None
try:
    import termios as _termios
    _SAVED_TC = _termios.tcgetattr(sys.stdin.fileno())
except Exception:
    pass

CONFIG_FILE = Path.home() / '.task' / 'config' / 'sanity.rc'
HOOKS_DIR   = Path.home() / '.task' / 'hooks'
VERSION     = '0.5.0'
DIVIDER     = '─' * 62

BOLD   = '\033[1m'
DIM    = '\033[2m'
GREEN  = '\033[32m'
CYAN   = '\033[36m'
YELLOW = '\033[33m'
RESET  = '\033[0m'


# ============================================================================
# Config
# ============================================================================

def load_rc(rc_file: Path) -> tuple:
    """Parse rc file. Returns (global_config dict, conditions list)."""
    global_cfg = {}
    raw = {}
    order = []
    if not rc_file.exists():
        return global_cfg, []
    with rc_file.open() as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith('#') or '=' not in line:
                continue
            k, _, v = line.partition('=')
            k = k.strip()
            v = v.split('#')[0].strip()
            if k.startswith('sanity.'):
                global_cfg[k[len('sanity.'):]] = v
            elif k.startswith('condition.'):
                parts = k.split('.', 2)
                if len(parts) != 3:
                    continue
                _, name, key = parts
                if name not in raw:
                    raw[name] = {'name': name}
                    order.append(name)
                raw[name][key] = v
    return global_cfg, [raw[n] for n in order]


def parse_actions(action_str: str) -> list:
    """Parse 'label|template, ...' → [(label, template, open_edit), ...].
    If label is 'edit', selecting that numbered option opens readline instead
    of running the command directly."""
    result = []
    for item in action_str.split(','):
        item = item.strip()
        if not item:
            continue
        if '|' in item:
            label, _, template = item.partition('|')
            label = label.strip()
            result.append((label, template.strip(), label.lower() == 'edit'))
        else:
            result.append(('', item.strip(), False))
    return result


# ============================================================================
# Task fetching
# ============================================================================

_TASK_SAFE  = ['task', 'rc.hooks=off', 'rc.confirmation=off',
               'rc.verbose=nothing', 'rc.context=none']
_diag_cache:  Optional[str]  = None
_stats_cache: Optional[dict] = None


def task_export(filter_str: str) -> list:
    filter_args = filter_str.split() if filter_str.strip() else []
    cmd = _TASK_SAFE + filter_args + ['export']
    result = subprocess.run(cmd, capture_output=True, text=True)
    if not result.stdout.strip():
        return []
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError:
        return []


def sort_tasks(tasks: list, sort_key: str) -> list:
    if not sort_key:
        return tasks
    reverse = sort_key.endswith('-')
    field = sort_key.rstrip('+-')
    return sorted(tasks, key=lambda t: t.get(field, ''), reverse=reverse)


def collect_orphans(filter_str: str) -> list:
    """Find +BLOCKED tasks whose dep is no longer pending."""
    all_pending  = task_export('+PENDING')
    pending_uuids = {t['uuid'] for t in all_pending}
    blocked = task_export(filter_str or '+PENDING +BLOCKED')
    orphans = []
    for task in blocked:
        for dep_uuid in task.get('depends', []):
            if dep_uuid not in pending_uuids:
                orphans.append(task)
                break
    return orphans


def _run_diag() -> str:
    global _diag_cache
    if _diag_cache is None:
        result = subprocess.run(['task', 'rc.hooks=off', 'diag'],
                                capture_output=True, text=True)
        _diag_cache = result.stdout
    return _diag_cache


def _run_stats() -> dict:
    global _stats_cache
    if _stats_cache is None:
        result = subprocess.run(
            ['task', 'rc.hooks=off', 'rc.context=none', 'stats'],
            capture_output=True, text=True,
        )
        _stats_cache = {}
        for line in result.stdout.split('\n'):
            m = re.match(r'^([A-Za-z][\w ]*?)\s{2,}(\d[\d,]*)', line)
            if m:
                _stats_cache[m.group(1).rstrip()] = m.group(2).replace(',', '')
    return _stats_cache


def _parse_diag_header() -> dict:
    """Extract version, platform, config file, data location from cached diag."""
    diag = _run_diag()
    info = {'version': '', 'platform': '', 'file': '', 'data': ''}
    home = str(Path.home())
    for line in diag.split('\n'):
        s = line.strip()
        if not info['version']:
            m = re.match(r'(?:task|Taskwarrior)\s+(\d[\d.]+)', s, re.I)
            if m:
                info['version'] = f'task {m.group(1)}'
        if not info['platform']:
            m = re.search(r'Platform[:\s]+(\w+)', s, re.I)
            if m:
                info['platform'] = m.group(1)
        if not info['file']:
            m = re.search(r'\bFile[:\s]+(/[^\s(]+)', s)
            if m:
                path = m.group(1).replace(home, '~')
                status = ' (found)' if 'found' in s else ' (missing)' if 'missing' in s else ''
                info['file'] = path + status
        if not info['data']:
            m = re.search(r'\bLocation[:\s]+(/[^\s(]+)', s)
            if m:
                path = m.group(1).rstrip('/').replace(home, '~')
                status = ' (found)' if 'found' in s else ' (missing)' if 'missing' in s else ''
                info['data'] = path + status
    return info


def collect_diag_hooks() -> list:
    """Inactive hooks from task diag — skips library files (not starting with on-)."""
    diag = _run_diag()
    issues = []
    in_inactive = False

    for line in diag.split('\n'):
        if re.search(r'\bInactive:', line):
            in_inactive = True
        elif in_inactive and re.match(r'^\s{0,12}\w[\w -]*:', line):
            in_inactive = False  # new labeled field, end of inactive block

        if not in_inactive:
            continue

        content = re.sub(r'^\s+(?:Inactive:\s*)?', '', line)
        m = re.match(r'(\S+)\s+\(([^)]+)\)', content)
        if not m:
            continue
        filename, reason = m.group(1), m.group(2)
        if not filename.startswith('on-'):
            continue  # library file — expected to be non-executable/unrecognised
        hook_path = str(HOOKS_DIR / filename)
        issues.append({
            'id': 0, 'uuid': filename,
            'description': f'{filename}  ({reason})',
            '_actions': [('make executable', f'chmod +x {hook_path}')],
        })
    return issues


_BROKEN_RE = re.compile(
    r'Task ([0-9a-f-]{36}) depends on nonexistent task: ([0-9a-f-]{36})'
)


def collect_diag_broken() -> list:
    """Tasks with broken dep references (dep UUID no longer exists at all)."""
    diag = _run_diag()
    broken: dict = {}
    for line in diag.split('\n'):
        m = _BROKEN_RE.search(line)
        if m:
            broken.setdefault(m.group(1), []).append(m.group(2))

    if not broken:
        return []

    # UUID-based lookup — works on any status (pending/completed/deleted)
    results = []
    for task_uuid, dep_uuids in broken.items():
        found = task_export(f'uuid:{task_uuid}')
        task = found[0] if found else {
            'uuid': task_uuid, 'id': 0,
            'description': f'Unknown task {task_uuid[:8]}',
        }
        n    = len(dep_uuids)
        args = ' '.join(f'dep:-{d}' for d in dep_uuids)
        task = dict(task)
        task['_actions'] = [(
            f'remove {n} broken dep{"s" if n > 1 else ""}',
            f'task rc.confirmation=off rc.verbose=nothing uuid:{task_uuid} modify {args}',
        )]
        results.append(task)
    return results


_DUP_RE = re.compile(r'Found duplicate ([0-9a-f-]{36})')


def collect_diag_dups() -> list:
    """Duplicate UUIDs reported by task diag — informational."""
    diag = _run_diag()
    issues = []
    for line in diag.split('\n'):
        m = _DUP_RE.search(line)
        if m:
            dup_uuid = m.group(1)
            issues.append({
                'id': 0, 'uuid': dup_uuid,
                'description': f'Duplicate UUID: {dup_uuid}',
                '_diag': True,
            })
    return issues


def collect_tasks(cond: dict) -> list:
    ctype = cond.get('type', '')
    if ctype == 'orphans':
        tasks = collect_orphans(cond.get('filter', ''))
    elif ctype == 'diag-hooks':
        tasks = collect_diag_hooks()
    elif ctype == 'diag-broken':
        tasks = collect_diag_broken()
    elif ctype == 'diag-dups':
        tasks = collect_diag_dups()
    else:
        tasks = task_export(cond.get('filter', ''))
    return sort_tasks(tasks, cond.get('sort', ''))


# ============================================================================
# Date utilities
# ============================================================================

def tw_to_date(tw_date: str) -> Optional[date]:
    if not tw_date:
        return None
    try:
        return datetime.strptime(tw_date[:8], '%Y%m%d').date()
    except (ValueError, TypeError):
        return None


def fmt_date(tw_date: str) -> str:
    d = tw_to_date(tw_date)
    return d.strftime('%Y-%m-%d') if d else ''


def age_str(tw_date: str) -> str:
    d = tw_to_date(tw_date)
    if not d:
        return ''
    delta = (date.today() - d).days
    if delta == 0:   return 'today'
    elif delta > 0:  return f'{delta}d ago'
    else:            return f'in {-delta}d'


_OFFSET_RE = re.compile(r'<(\w+)([+-]\d+[dwmy])?>')


def compute_action(template: str, task: dict) -> str:
    """Interpolate <field> and <field±Nd/w/m/y> tokens with real task dates."""
    if not template:
        return ''

    def replace(m):
        field  = m.group(1)
        offset = m.group(2) or ''
        base   = date.today() if field == 'today' else tw_to_date(task.get(field, ''))
        if not base:
            return m.group(0)
        if offset:
            sign = 1 if offset[0] == '+' else -1
            num  = int(offset[1:-1])
            unit = offset[-1]
            days = {'d': num, 'w': num * 7, 'm': num * 30, 'y': num * 365}[unit]
            base = base + timedelta(days=days * sign)
        return base.strftime('%Y-%m-%d')

    return _OFFSET_RE.sub(replace, template)


# ============================================================================
# Display
# ============================================================================

def clear_screen():
    os.system('clear')


def show_task(task: dict):
    tid  = task.get('id') or 0
    desc = task.get('description', '')
    proj = task.get('project', '')
    pri  = task.get('priority', '')

    meta = []
    if proj: meta.append(f'project:{proj}')
    if pri:  meta.append(f'pri:{pri}')
    for field in ('due', 'scheduled', 'wait', 'until'):
        val = task.get(field, '')
        if val:
            meta.append(f'{field}:{fmt_date(val)} ({age_str(val)})')
    deps = task.get('depends', [])
    if deps:
        meta.append(f'deps:{len(deps)}')

    if tid:
        print(f'\n  {BOLD}{GREEN}[{tid}] {desc}{RESET}')
    else:
        print(f'\n  {BOLD}{GREEN}{desc}{RESET}')
    if meta:
        print(f'       {CYAN}{" · ".join(meta)}{RESET}')


# ============================================================================
# Input helpers
# ============================================================================

def _getch() -> str:
    """Read one keypress in raw mode; falls back to line input if not a TTY."""
    if not sys.stdin.isatty():
        line = sys.stdin.readline()
        return (line.strip()[:1] if line.strip() else '\r')
    try:
        import tty, termios
    except ImportError:
        ch = input().strip()
        return ch[:1] if ch else '\r'
    fd  = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        ch = sys.stdin.read(1)
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
    sys.stdout.write('\n')
    sys.stdout.flush()
    return ch


def _restore_terminal():
    """Restore terminal to the clean state saved at startup."""
    if _SAVED_TC is not None:
        try:
            import termios
            termios.tcsetattr(sys.stdin.fileno(), termios.TCSAFLUSH, _SAVED_TC)
        except Exception:
            pass


def prompt_prefill(prompt_text: str, prefill: str) -> Optional[str]:
    """Returns the edited string, or None if the user pressed Ctrl-C."""
    result = None
    try:
        import readline
        readline.set_startup_hook(lambda: readline.insert_text(prefill))
        try:
            result = input(prompt_text)
        except KeyboardInterrupt:
            print()
        finally:
            readline.set_startup_hook(None)
    except ImportError:
        try:
            result = input(f'{prompt_text}[{prefill}] ')
        except KeyboardInterrupt:
            print()
    finally:
        _restore_terminal()

    return result


# ============================================================================
# Review loop
# ============================================================================

def _run_edit(prefill: str, tid, skip_uuids: set, uuid: str,
              remaining: list) -> Optional[bool]:
    """Open readline edit prompt. Returns True=advanced, False=quit, None=loop."""
    response = prompt_prefill('  Fix > ', prefill)
    if response is None:
        return None  # Ctrl-C → loop
    response = response.strip()
    if not response or response.lower() == 's':
        skip_uuids.add(uuid)
        remaining.pop(0)
        return True
    elif response.lower() == 'q':
        return False
    elif response.lower() == 'd' and tid:
        subprocess.run(['task', 'rc.confirmation=off', str(tid), 'done'])
        remaining.pop(0)
        return True
    else:
        result = subprocess.run(response.split())
        if result.returncode == 0:
            remaining.pop(0)
            return True
        else:
            print('  [command failed — edit and retry, or s to skip]')
            return None


def review_condition(cond: dict, tasks: list, clear_term: str = 'no') -> bool:
    """Interactive review of one condition. Returns False to quit session."""
    name    = cond['name']
    msg     = cond.get('msg', name)
    total   = len(tasks)
    has_cal = 'calendar' in cond.get('helpers', '')
    actions = parse_actions(cond.get('action', ''))

    if clear_term == 'condition':
        clear_screen()

    print(f'\n{"═" * 62}')
    print(f'  {name} — {msg}')
    print(f'  {total} task{"s" if total != 1 else ""}')
    print(f'{"═" * 62}')

    if not tasks:
        print('  Nothing to fix.')
        return True

    # Informational-only conditions
    if cond.get('type') in ('diag', 'diag-dups'):
        for t in tasks:
            print(f'  ▶ {t["description"]}')
        input('\n  Press Enter to continue...')
        return True

    skip_uuids = set()
    remaining  = list(tasks)
    show_cal   = False

    _CAL_CMD = ['task',
                'rc.verbose=nothing',
                'rc.calendar.details=none',
                'rc.calendar.legend=0',
                'rc.calendar.monthsperline=4',
                'rc.displayweeknumber=0',
                'calendar']

    while remaining:
        task = remaining[0]
        uuid = task.get('uuid', '')

        if uuid in skip_uuids:
            remaining.pop(0)
            continue

        if clear_term == 'task':
            clear_screen()
            # Re-show condition context after clear
            print(f'  {CYAN}{name}{RESET} — {msg}')
            print(DIVIDER)
            if show_cal:
                subprocess.run(_CAL_CMD)

        done_count = total - len(remaining)
        show_task(task)

        tid       = task.get('id') or 0
        is_pseudo = not bool(tid)

        # Actions: per-task prebuilt (_actions) or computed from condition template
        if '_actions' in task:
            computed = [(lbl, cmd, False) for lbl, cmd in task['_actions']]
        else:
            computed = []
            for label, template, open_edit in actions:
                cmd = compute_action(template, task)
                computed.append((label, f'task {tid} {cmd}' if cmd else '', open_edit))

        # Numbered fixes
        if computed:
            print()
            lw = max((len(lbl) for lbl, _, _ in computed if lbl), default=0)
            for i, (label, cmd, open_edit) in enumerate(computed, 1):
                lbl_str = f'{label:<{lw}}  ' if label else ''
                print(f'  {YELLOW}{i}{RESET}  {lbl_str}{cmd}')

        # Letter hotkeys — suppress task-specific ones for pseudo-tasks
        hotkeys = []
        if has_cal and not is_pseudo:
            cal_label = 'c=hide-cal' if show_cal else 'c=calendar'
            hotkeys.append(cal_label)
        if not is_pseudo:
            hotkeys += ['i=info', 'd=done']
        hotkeys.append('q=quit')
        print(f'\n  ({done_count + 1}/{total})  {CYAN}{"  ".join(hotkeys)}{RESET}  Enter=skip')

        key = _getch()

        if key in ('\x03', '\x1b', 'q', 'Q'):
            return False

        elif key in ('\r', '\n'):
            skip_uuids.add(uuid)
            remaining.pop(0)

        elif key in ('d', 'D') and not is_pseudo:
            subprocess.run(['task', 'rc.confirmation=off', str(tid), 'done'])
            remaining.pop(0)

        elif key in ('c', 'C') and has_cal and not is_pseudo:
            show_cal = not show_cal
            # loop — re-renders with/without calendar

        elif key in ('i', 'I') and not is_pseudo:
            subprocess.run(['task', 'rc.verbose=nothing', 'rc.journal.info=0',
                            'rc.hooks=off', str(tid), 'info'])
            _getch()  # any key to dismiss, then re-render

        elif key.isdigit() and 1 <= int(key) <= len(computed):
            label, cmd, open_edit = computed[int(key) - 1]
            if open_edit:
                r = _run_edit(cmd or f'task {tid} ', tid, skip_uuids, uuid, remaining)
                if r is False:
                    return False
            elif cmd:
                result = subprocess.run(cmd.split())
                if result.returncode == 0:
                    remaining.pop(0)
                else:
                    print('  [command failed — press s to skip]')
            else:
                print('  [no command for this task]')

        # unrecognised key: loop, show task again

    print(f'\n  ✓ {name} complete')
    return True


# ============================================================================
# Menu (no-args)
# ============================================================================

def _rjust_line(left: str, right: str) -> str:
    """Left content + right-justified label within DIVIDER width."""
    pad = len(DIVIDER) - len(left) - len(right)
    return left + ' ' * max(pad, 2) + right


def cmd_menu(conditions: list, clear_term: str = 'no'):
    today = date.today().strftime('%Y-%m-%d')
    diag  = _parse_diag_header()
    stats = _run_stats()

    print(f'\nTaskwarrior Sanity check — {today}')
    print(DIVIDER)

    ver_plat = diag['version']
    if diag['platform']:
        ver_plat += f' - Platform: {diag["platform"]}'
    if ver_plat:
        print(ver_plat)
    if diag['file']:
        print(f'File:{diag["file"]}')
    if diag['data']:
        print(_rjust_line(f'Data:{diag["data"]}', 'see: task diag'))

    print(DIVIDER)

    stat_keys = ['Pending', 'Waiting', 'Recurring', 'Completed', 'Deleted', 'Total']
    W = 20
    for key in stat_keys:
        val = stats.get(key, '')
        if not val:
            continue
        left = f'{key:<{W}}{val:>6}'
        if key == 'Total':
            print(_rjust_line(left, 'see: task stats'))
        else:
            print(left)

    print(DIVIDER)

    agenda = [(cond, collect_tasks(cond)) for cond in conditions]
    total  = sum(len(tasks) for _, tasks in agenda)
    width  = max(len(c['name']) for c in conditions) if conditions else 10

    for i, (cond, tasks) in enumerate(agenda, 1):
        n    = len(tasks)
        flag = '▶ ' if n else '  '
        desc = cond.get('description', '')
        row  = f'  {flag}{i:>2}. {cond["name"]:<{width}}  {n:>3}   {desc}'
        print(f'{DIM}{row}{RESET}' if n == 0 else row)

    print(DIVIDER)
    if total == 0:
        print('  All clear.\n')
        return

    print(f'  {total} issue{"s" if total != 1 else ""}')

    use_getch = len(agenda) < 10
    if use_getch:
        print(f'\n  Select [1-{len(agenda)}]  a=all  q=quit  Enter=quit')
        key = _getch()
    else:
        print(f'\n  Select [1-{len(agenda)}]  a=all  q=quit  Enter=quit')
        try:
            key = input('  > ').strip() or '\r'
        except (KeyboardInterrupt, EOFError):
            print()
            return

    if not key or key in ('\x03', '\x1b', 'q', 'Q', '\r', '\n'):
        return
    elif key.lower() == 'a':
        selected = agenda
    else:
        try:
            n = int(key)
            if 1 <= n <= len(agenda):
                selected = [agenda[n - 1]]
            else:
                print(f'  Out of range: {n}')
                return
        except ValueError:
            print(f'  Unknown: {key!r}')
            return

    print()
    for cond, tasks in selected:
        if not tasks:
            continue
        if not review_condition(cond, tasks, clear_term):
            print('\n[sanity-check] Session ended.')
            break

    print()


# ============================================================================
# Main
# ============================================================================

def main() -> int:
    global_cfg, conditions = load_rc(CONFIG_FILE)
    if not conditions:
        print(f'[sanity-check] No conditions found in {CONFIG_FILE}', file=sys.stderr)
        return 1

    clear_term = global_cfg.get('clear-term', 'no').lower()

    args = sys.argv[1:]

    if not args:
        cmd_menu(conditions, clear_term)
        return 0

    target = args[0].lower()

    if target == 'all':
        selected = conditions
    else:
        selected = [c for c in conditions if c['name'] == target]
        if not selected:
            print(f'[sanity-check] Unknown condition: {target}', file=sys.stderr)
            print(f'  Known: {", ".join(c["name"] for c in conditions)}',
                  file=sys.stderr)
            return 1

    agenda = [(cond, collect_tasks(cond)) for cond in selected]
    total  = sum(len(tasks) for _, tasks in agenda)

    if total == 0:
        print('\nAll clear — no issues found.')
        return 0

    print(f'\nSanity check — {date.today().strftime("%Y-%m-%d")}')
    for cond, tasks in agenda:
        if tasks:
            print(f'  ▶ {cond["name"]:<24} {len(tasks):>3} task{"s" if len(tasks) != 1 else ""}')
    print()

    for cond, tasks in agenda:
        if not tasks:
            continue
        if not review_condition(cond, tasks, clear_term):
            print('\n[sanity-check] Session ended.')
            break

    print()
    return 0


if __name__ == '__main__':
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        print()
        sys.exit(0)
